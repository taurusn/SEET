# Database
DATABASE_URL=postgresql+asyncpg://cafe_user:cafe_pass@db:5432/cafe_reply
DATABASE_URL_SYNC=postgresql://cafe_user:cafe_pass@db:5432/cafe_reply

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://cafe_mq:cafe_mq_pass@rabbitmq:5672/
RABBITMQ_USER=cafe_mq
RABBITMQ_PASS=cafe_mq_pass

# Meta Platform
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_webhook_verify_token

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# JWT (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=your-jwt-secret-here

# PostgreSQL (used by docker-compose)
POSTGRES_USER=cafe_user
POSTGRES_PASSWORD=cafe_pass
POSTGRES_DB=cafe_reply

# Frontend
FRONTEND_URL=http://localhost:3000

# Tunnel (auto-generated — check `docker compose logs tunnel` for the public URL)
# Use the tunnel URL as your Meta webhook URL: https://<random>.trycloudflare.com/webhook/instagram

# App
APP_ENV=development
LOG_LEVEL=INFO

# Woodpecker CI/CD
# Create a GitHub OAuth App: https://github.com/settings/developers
#   Homepage URL: http://localhost:8080
#   Authorization callback URL: http://localhost:8080/authorize
WOODPECKER_HOST=http://localhost:8080
WOODPECKER_ADMIN=hatim
WOODPECKER_GITHUB_CLIENT=your-github-oauth-client-id
WOODPECKER_GITHUB_SECRET=your-github-oauth-client-secret
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WOODPECKER_AGENT_SECRET=your-agent-secret
