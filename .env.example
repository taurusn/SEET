# Database
DATABASE_URL=postgresql+asyncpg://cafe_user:cafe_pass@db:5432/cafe_reply
DATABASE_URL_SYNC=postgresql://cafe_user:cafe_pass@db:5432/cafe_reply

# Redis (generate password with: python -c "import secrets; print(secrets.token_urlsafe(32))")
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:your-redis-password-here@redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://cafe_mq:cafe_mq_pass@rabbitmq:5672/
RABBITMQ_USER=cafe_mq
RABBITMQ_PASS=cafe_mq_pass

# Meta Platform
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_webhook_verify_token

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# JWT (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=your-jwt-secret-here

# PostgreSQL (used by docker-compose)
POSTGRES_USER=cafe_user
POSTGRES_PASSWORD=cafe_pass
POSTGRES_DB=cafe_reply

# Frontend
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=seet-admin
MINIO_ROOT_PASSWORD=seet-secret-change-me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=seet-assets

# Cloudflare Tunnel (named tunnel token from Cloudflare Zero Trust → Access → Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# App
APP_ENV=development
LOG_LEVEL=INFO

# Woodpecker CI/CD
# Create a GitHub OAuth App: https://github.com/settings/developers
#   Homepage URL: http://localhost:8080
#   Authorization callback URL: http://localhost:8080/authorize
WOODPECKER_HOST=http://localhost:8080
WOODPECKER_ADMIN=hatim
WOODPECKER_GITHUB_CLIENT=your-github-oauth-client-id
WOODPECKER_GITHUB_SECRET=your-github-oauth-client-secret
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WOODPECKER_AGENT_SECRET=your-agent-secret

# ─── CI notifications (Woodpecker → email) ──────────────────────────────────
# Gmail SMTP. CI_SMTP_PASS must be a 16-char app password from
# https://myaccount.google.com/apppasswords (not your Google login).
CI_SMTP_HOST=smtp.gmail.com
CI_SMTP_PORT=465
CI_SMTP_USER=your@gmail.com
CI_SMTP_PASS=<16-char-app-password>
CI_NOTIFY_TO=your@gmail.com
